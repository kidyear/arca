{
  "name": "arca",
  "version": "1.0.11",
  "description": "灵匣 Arca — 文件夹操作 × AI Agent 的结合体。匣中有灵:文件信手可得,活儿交给 AI 办。深圳信步科技 SEAVO 出品。",
  "bin": {
    "fanbox": "server.js"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "app": "electron .",
    "rebuild": "electron-rebuild -f -w node-pty",
    "build:milkdown": "esbuild src-vendor/milkdown-entry.js --bundle --format=iife --minify --outfile=public/vendor/milkdown/milkdown.js --loader:.svg=dataurl --loader:.woff=file --loader:.woff2=file --loader:.ttf=file --loader:.eot=file --asset-names=[name]",
    "build:hljs": "esbuild src-vendor/hljs-entry.js --bundle --format=iife --minify --outfile=public/vendor/hljs/highlight.js && cp node_modules/marked/marked.min.js public/vendor/marked/marked.min.js && cp node_modules/highlight.js/styles/github-dark.min.css node_modules/highlight.js/styles/github.min.css public/vendor/hljs/styles/",
    "check:vendor-patch": "grep -q '20===e.keyCode||229===e.keyCode' public/vendor/xterm/xterm.js",
    "predist": "npm run check:vendor-patch",
    "dist": "electron-builder --mac",
    "dist:win": "electron-rebuild -f -w node-pty && electron-builder --win",
    "build:docx": "esbuild src-vendor/docx-entry.jsx --bundle --format=iife --minify --jsx=automatic --define:process.env.NODE_ENV=\\\"production\\\" --outfile=public/vendor/docx/docx-editor.js --loader:.woff=file --loader:.woff2=file --loader:.ttf=file --loader:.svg=dataurl --loader:.png=dataurl",
    "build:xlsx": "esbuild src-vendor/xlsx-entry.js --bundle --format=iife --minify --outfile=public/vendor/xlsx/xlsx.js"
  },
  "build": {
    "appId": "com.seavo.arca",
    "productName": "Arca",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "**/node_modules/node-pty/**",
      "**/node_modules/@anthropic-ai/claude-agent-sdk/**",
      "**/node_modules/@anthropic-ai/claude-agent-sdk-*/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "identity": "Apple Development: chen yunfei (FG7WYU86RP)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        }
      ]
    },
    "dmg": {
      "title": "灵匣 Arca",
      "writeUpdateInfo": false
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        }
      ],
      "artifactName": "Arca-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "灵匣 Arca",
      "uninstallDisplayName": "灵匣 Arca"
    }
  },
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.172",
    "@eigenpal/docx-editor-agents": "^1.4.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eigenpal/docx-editor-react": "^1.4.0",
    "@electron/rebuild": "^3.7.0",
    "@milkdown/crepe": "^7.21.2",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2",
    "monaco-editor": "^0.52.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "^0.18.5"
  },
  "license": "MIT",
  "author": "SEAVO 信步科技"
}
